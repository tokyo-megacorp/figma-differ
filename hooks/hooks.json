{
  "description": "figma-differ dogfood hooks — nudge, track, and loop",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pedro/Developer/figma-differ/scripts/hooks/dogfood-stop.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pedro/Developer/figma-differ/scripts/hooks/validate-snapshots.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/pedro/Developer/figma-differ/scripts/hooks/dogfood-prompt.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/mcp-routing.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
